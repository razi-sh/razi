name: customer_sentiment_analysis
version: 1.0.0
policy: enterprise_support_v1

model:
  provider: openai
  id: gpt-4o-mini
  temperature: 0.1

input_schema: examples/schemas/sentiment_input.json
output_schema: examples/schemas/sentiment_output.json

operators:
  - type: synth.json
    id: synthesis
    template: examples/templates/sentiment_rules.txt
    max_attempts: 3
    confidence_threshold: 0.0
