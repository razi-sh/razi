{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "sentiment": {
            "type": "string",
            "enum": [
                "positive",
                "neutral",
                "negative"
            ],
            "description": "The classified sentiment of the text."
        },
        "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1.0,
            "description": "AI confidence in its classification."
        },
        "reasoning": {
            "type": "string",
            "description": "A short, one-sentence explanation for the sentiment."
        }
    },
    "required": [
        "sentiment",
        "confidence",
        "reasoning"
    ],
    "additionalProperties": false
}