{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "id": {
            "type": "integer"
        },
        "subject": {
            "type": "string"
        },
        "description": {
            "type": "string"
        },
        "priority": {
            "type": [
                "string",
                "null"
            ]
        },
        "tags": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "requester_id": {
            "type": "integer"
        },
        "created_at": {
            "type": "string"
        }
    },
    "required": [
        "id",
        "subject",
        "description"
    ]
}